# Application
NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sitetrack
DB_USER=sitetrack
DB_PASSWORD=sitetrack_dev

# JWT
JWT_SECRET=change-this-in-production-use-long-random-string
# Short-lived access tokens (refresh handled via refresh_tokens table)
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Initial admin seed - leave empty to skip seeding
SEED_ADMIN_EMAIL=admin@sitetrack.com
SEED_ADMIN_PASSWORD=password123
