# Next.js reads NEXT_PUBLIC_* vars at build time (browser-accessible)
# Other vars are server-only

# Public: the GraphQL endpoint seen from the browser
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3001/graphql
NEXT_PUBLIC_GRAPHQL_WS_URL=ws://localhost:3001/graphql

# Server-only: NextAuth config
NEXTAUTH_SECRET=change-this-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# Server-only: backend URL for Server Component fetches (container-to-container)
BACKEND_URL=http://localhost:3001
