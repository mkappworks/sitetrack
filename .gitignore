# ── Dependencies ──────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Environment files (NEVER commit — contain secrets) ────────────────────
# .env.example is tracked; real .env files are not.
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local

# ── Build output ──────────────────────────────────────────────────────────
# NestJS
backend/dist/
# Next.js
frontend/.next/
frontend/out/
frontend/next-env.d.ts
# TypeScript incremental build info
*.tsbuildinfo

# ── Test / coverage artifacts ─────────────────────────────────────────────
coverage/
.nyc_output/

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Editor / IDE ──────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Local Kubernetes / Docker state ───────────────────────────────────────
# Compose volumes are managed by Docker, but stray dumps land here.
*.pid
.docker/

# ── Real Kubernetes Secrets (NEVER commit) ────────────────────────────────
# Only the *.example.yaml templates are tracked. Real Secret manifests
# are created out-of-tree (see k8s/*/secret.example.yaml for guidance).
k8s/**/secret.yaml
!k8s/**/secret.example.yaml
